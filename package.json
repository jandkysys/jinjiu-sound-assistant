{
  "name": "@workspace/sound-assistant",
  "version": "1.0.5",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --config vite.config.mts --host 0.0.0.0",
    "dev:local": "concurrently -k \"vite --config vite.config.electron.ts --host 0.0.0.0\" \"wait-on tcp:3000 && electron .\"",
    "build": "vite build --config vite.config.mts",
    "electron": "electron .",
    "build:electron": "vite build --config vite.electron.config.ts",
    "dist:win": "npm run build:electron && electron-builder --win",
    "dist:mac": "pnpm run build:electron && electron-builder --mac",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:backend-config": "node scripts/verify-production-backend.mjs",
    "check:backend": "node scripts/check-production-backend.mjs",
    "verify:nondestructive-sync": "node scripts/verify-nondestructive-sync.mjs",
    "verify:standalone-float": "node scripts/verify-standalone-float-window.mjs",
    "verify:single-audio-owner": "node scripts/verify-single-audio-owner.mjs",
    "verify:hotkeys-start-disabled": "node scripts/verify-hotkeys-start-disabled.mjs",
    "verify:hotkey-window-sync": "node scripts/verify-hotkey-window-sync.mjs",
    "verify:full-sound-keyboard": "node scripts/verify-full-sound-keyboard.mjs",
    "verify:shortcut-listen-and-capture": "node scripts/verify-shortcut-listen-and-capture.mjs",
    "verify:scoped-player-ui": "node scripts/verify-scoped-player-ui.mjs",
    "verify:bgm-player-controls": "node scripts/verify-bgm-player-controls.mjs",
    "verify:ascii-delivery": "node scripts/verify-ascii-windows-delivery.mjs",
    "test:audio-policy": "node --experimental-strip-types --test src/lib/audioUploadPolicy.test.ts",
    "verify:audio-upload-policy": "node scripts/verify-audio-upload-policy.mjs",
    "test:sync-conflicts": "node --experimental-strip-types --test src/lib/syncConflicts.test.ts",
    "test:direct-shortcut-key": "node --experimental-strip-types --test src/lib/directShortcutKey.test.ts",
    "test:shortcut-conflict-policy": "node --experimental-strip-types --test src/lib/shortcutConflictPolicy.test.ts",
    "test:scoped-player": "node --experimental-strip-types --test src/lib/scopedPlayer.test.ts",
    "test:shortcut-interaction": "node --experimental-strip-types --test src/lib/shortcutInteraction.test.ts",
    "verify:sync-conflict-preflight": "node scripts/verify-sync-conflict-preflight.mjs",
    "verify:sound-conflict-ui": "node scripts/verify-sound-conflict-ui.mjs"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@replit/vite-plugin-cartographer": "^0.5.1",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^10.0.3",
    "date-fns": "^3.6.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.24",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "pinyin-pro": "^3.28.1",
    "png-to-ico": "^3.0.1",
    "react": "19.1.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vaul": "^1.1.2",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10",
    "wouter": "^3.3.5",
    "zod": "^3.25.76"
  }
}
